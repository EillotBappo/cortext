#!/usr/bin/env python3
"""cortext-bench — model the token/cost tradeoff of cortext vs the native approaches.

This is a *model*, not a live measurement: it computes, from stated per-subtask
assumptions, how many tokens land on the expensive planner model vs cheap Haiku
under three approaches, so the README's comparison numbers are reproducible and
tunable rather than hand-waved. Edit the constants below to fit your own numbers
and re-run — the whole point is that the assumptions are visible knobs.

Three approaches, same fan-out task (N independent subtasks):

  inline-opus   one Opus agent does everything in one context. No per-agent
                schema overhead, but every file read and every output token is
                on the expensive model.
  native-subs   N native Task subagents on the DEFAULT model (Opus), each a
                full-access agent that loads EVERY tool schema. Expensive model
                *and* the biggest per-agent context overhead.
  cortext       Opus only plans (tiny briefs) + integrates (terse results). N
                scoped Haiku subagents (4-6 tools) grind the work off the
                planner's context.

Cost is in relative units: 1 unit per Haiku token, OPUS_WEIGHT units per Opus
token (Haiku 4.5 is ~15x cheaper than Opus per token, input and output alike).
Prompt-cache discounts are IGNORED — that's conservative *against* cortext,
whose per-agent schema overhead is mostly cached, so real savings run higher.

  cortext-bench            # print the comparison table
  cortext-bench --selftest # arithmetic self-check
"""
import sys

# ---- knobs (edit to taste; these are the only assumptions) -------------------
OPUS_WEIGHT = 15       # cost per Opus token, relative to a Haiku token (~15x list price)
BRIEF_OUT = 150        # Opus output tokens to write one subtask brief
RESULT_IN = 350        # Opus input tokens to read one terse result back
SCOPED_SCHEMA = 15_000  # per-subagent context for a scoped 4-6 tool Haiku agent
FULL_SCHEMA = 40_000    # per-subagent context for a full-access native subagent

# ---- scenarios: (name, n_subtasks, ctx_per_subtask, out_per_subtask) ---------
SCENARIOS = [
    ("Wide audit (read-only)",   8, 4_000, 800),   # "audit error handling across all views"
    ("Batch mechanical edit",   12, 3_000, 500),   # "add a deprecated flag to every exported fn + docs"
    ("Small fan-out (3 checks)",  3, 5_000, 1_000),  # "check A and B and C"
    ("Big refactor sweep",      20, 6_000, 1_200),  # "migrate every call site to the new API"
]


def costs(n, ctx, out):
    """Return {approach: (opus_tokens, haiku_tokens, cost_units)} for one scenario."""
    work_ctx, work_out = n * ctx, n * out

    def cost(opus, haiku):
        return OPUS_WEIGHT * opus + haiku

    inline_opus = work_ctx + work_out
    native_opus = work_ctx + n * FULL_SCHEMA + work_out
    ct_opus = n * (BRIEF_OUT + RESULT_IN)          # orchestration only
    ct_haiku = work_ctx + n * SCOPED_SCHEMA + work_out  # grunt, on Haiku

    return {
        "inline-opus": (inline_opus, 0, cost(inline_opus, 0)),
        "native-subs": (native_opus, 0, cost(native_opus, 0)),
        "cortext":     (ct_opus, ct_haiku, cost(ct_opus, ct_haiku)),
    }


def _pct(a, b):
    return round(100 * (a - b) / a) if a else 0


def _human(n):
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    return f"{n/1000:.0f}k" if n >= 1000 else str(n)


def barchart(title, rows, width=34):
    """rows = [(label, value)]. Horizontal bars scaled to the largest value."""
    hi = max((v for _, v in rows), default=0) or 1
    out = [title, ""]
    for label, v in rows:
        fill = round(width * v / hi)
        bar = "█" * fill + "·" * (width - fill)
        out.append(f"  {label:<13} {bar} {_human(v)}")
    return "\n".join(out)


def render():
    # Hero: one scenario shown as bar charts — the headline anyone can grok in a
    # glance. Lower is better on both.
    name, n, ctx, out = SCENARIOS[0]
    c = costs(n, ctx, out)
    order = ("native-subs", "inline-opus", "cortext")
    lines = [
        "cortext-bench — modelled comparison vs the native approaches",
        "(assumptions in --help; lower is better)",
        "",
        barchart(f"Tokens on your EXPENSIVE model — {name} (x{n}):",
                 [(a, c[a][0]) for a in order]),
        "",
        barchart(f"Blended cost (Haiku token=1, Opus=15) — {name} (x{n}):",
                 [(a, c[a][2]) for a in order]),
        "",
        f"  → cortext puts ~99% fewer tokens on the expensive model and costs",
        f"    {_pct(c['native-subs'][2], c['cortext'][2])}% less than native subagents.",
        "",
        "  All four use cases:",
        "",
        f"  {'approach':<14}{'opus tok':>9}   {'cost':>7}   {'vs cortext':<14}",
        "  " + "-" * 50,
    ]
    for name, n, ctx, out in SCENARIOS:
        c = costs(n, ctx, out)
        ct_cost = c["cortext"][2]
        lines.append(f"  {name}  (x{n} subtasks)")
        for appr in ("inline-opus", "native-subs", "cortext"):
            opus, _haiku, cost = c[appr]
            tail = "—" if appr == "cortext" else f"{cost/ct_cost:.1f}x pricier"
            lines.append(
                f"  {appr:<14}{_human(opus):>9}   {_human(cost):>7}   {tail:<14}"
            )
        off = _pct(c["native-subs"][0], c["cortext"][0])
        save_inline = _pct(c["inline-opus"][2], ct_cost)
        save_native = _pct(c["native-subs"][2], ct_cost)
        lines.append(
            f"  → {off}% of expensive tokens offloaded · "
            f"{save_inline}% cheaper than inline · {save_native}% than native subs"
        )
        lines.append("")
    lines.append("  Model, not a measurement. Cache discounts ignored (conservative).")
    lines.append("  cortext moves MORE raw tokens (per-agent schema x N) — but onto")
    lines.append("  cheap Haiku and off your planner's context. That is the trade.")
    return "\n".join(lines)


def selftest():
    # Wide audit: 8 subtasks, 4k ctx, 0.8k out.
    c = costs(8, 4_000, 800)
    # inline opus tokens = 8*(4000+800) = 38400
    assert c["inline-opus"][0] == 38_400, c
    # native opus tokens = 32000 + 8*40000 + 6400 = 358400
    assert c["native-subs"][0] == 358_400, c
    # cortext opus tokens = 8*(150+350) = 4000
    assert c["cortext"][0] == 4_000, c
    # cortext haiku = 32000 + 8*15000 + 6400 = 158400
    assert c["cortext"][1] == 158_400, c
    # cortext cost = 15*4000 + 158400 = 218400
    assert c["cortext"][2] == 218_400, c
    # inline cost = 15*38400 = 576000; native = 15*358400 = 5376000
    assert c["inline-opus"][2] == 576_000 and c["native-subs"][2] == 5_376_000, c
    # cortext offloads 4000/358400 of expensive tokens -> 99% off native
    assert _pct(c["native-subs"][0], c["cortext"][0]) == 99, _pct(c["native-subs"][0], c["cortext"][0])
    # and is ~62% cheaper than inline opus, ~96% than native subs
    assert _pct(c["inline-opus"][2], c["cortext"][2]) == 62
    assert _pct(c["native-subs"][2], c["cortext"][2]) == 96
    assert _human(1_500_000) == "1.5M" and _human(38_400) == "38k" and _human(500) == "500"
    # barchart: the max value fills the whole width, a 0 fills none.
    chart = barchart("t", [("big", 100), ("zero", 0)], width=10)
    assert "█" * 10 in chart and "·" * 10 in chart, chart
    print("selftest ok")
    return 0


def main(argv):
    if "--selftest" in argv:
        return selftest()
    print(render())
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
