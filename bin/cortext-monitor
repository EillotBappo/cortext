#!/usr/bin/env python3
"""cortext-monitor — live TUI for cortext subagents.

Reads the per-subagent transcripts Claude Code already writes plus the
orchestrator's .cortext/tasks.json manifest, and renders a per-subagent
progress + token dashboard.

Data sources (all native, nothing to instrument):
  - ~/.claude/projects/<slug>/<session-id>/subagents/agent-*.jsonl
        one file per subagent : per-message token usage + tool_use
  - ./.cortext/tasks.json
        labels + progress/token ceilings

Subagents are attributed by the `[cortext:<tag>]` marker the skill puts at the
start of every subagent prompt.

Usage:
  cortext-monitor            # live loop in this project
  cortext-monitor --once     # render one frame and exit (non-TTY / CI)
  cortext-monitor <dir>      # watch a specific subagents/ directory
  cortext-monitor --selftest # run parser self-checks

Live keys: q quit · r rescan (re-pick the active session) · c clear+repaint.

ponytail: progress % is a tool-call estimate (calls/budget), not ground truth —
it pins at 100% while a subagent keeps going past its budget. Upgrade path: have
subagents write a real step count to the manifest if a truthful bar is needed.
"""
import json, os, re, sys, glob

TAG_RE = re.compile(r"\[cortext:([\w.\-]+)\]")
BARW = 10
SPIN = "|/-\\"


def _slug(path):
    return re.sub(r"[^A-Za-z0-9]", "-", path)


def _cwd_and_parents():
    p = os.getcwd()
    out = []
    while True:
        out.append(p)
        parent = os.path.dirname(p)
        if parent == p:
            return out
        p = parent


def _subagents_of(session_path):
    sid = os.path.basename(session_path)[:-len(".jsonl")]
    return os.path.join(os.path.dirname(session_path), sid, "subagents")


def newest_subagents_dir():
    """subagents/ dir where subagents are actually running. Prefers sessions
    whose project is the cwd or any parent (so a subdir still finds it), then
    picks the one with the most recently written agent file — not the session
    with the newest mtime, which can be an idle session touched last. Falls back
    to the newest session so an empty dashboard still names the active session."""
    base = os.path.expanduser("~/.claude/projects")
    sessions = glob.glob(os.path.join(base, "*", "*.jsonl"))
    if not sessions:
        return None
    slugs = {_slug(p) for p in _cwd_and_parents()}
    preferred = [s for s in sessions
                 if os.path.basename(os.path.dirname(s)) in slugs] or sessions

    best, best_mt = None, -1.0
    for s in preferred:
        sub = _subagents_of(s)
        afiles = glob.glob(os.path.join(sub, "agent-*.jsonl"))
        if afiles:
            mt = max(os.path.getmtime(a) for a in afiles)
            if mt > best_mt:
                best, best_mt = sub, mt
    if best:
        return best
    return _subagents_of(max(preferred, key=os.path.getmtime))


def agent_files(subdir):
    return sorted(glob.glob(os.path.join(subdir, "agent-*.jsonl"))) if subdir else []


def find_agent_file(agent_id):
    """Locate one subagent transcript by id, independent of cwd — statuslines and
    hooks may run from a worktree, not the project root. Returns None if absent."""
    if not agent_id:
        return None
    aid = agent_id[len("agent-"):] if agent_id.startswith("agent-") else agent_id
    base = os.path.expanduser("~/.claude/projects")
    hits = glob.glob(os.path.join(base, "*", "*", "subagents", f"agent-{aid}.jsonl"))
    return max(hits, key=os.path.getmtime) if hits else None


def manifest_at(root):
    """Load the cortext manifest from an explicit project root (CLAUDE_PROJECT_DIR),
    not cwd — the statusline/hook cwd may be a worktree where .cortext is absent."""
    try:
        with open(os.path.join(root, ".cortext", "tasks.json")) as f:
            data = json.load(f)
    except (OSError, ValueError):
        return {}
    if not isinstance(data, list):
        return {}
    return {t["tag"]: t for t in data if isinstance(t, dict) and "tag" in t}


def load_objs(path):
    objs = []
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        objs.append(json.loads(line))
                    except ValueError:
                        pass
    except OSError:
        pass
    return objs


def load_manifest():
    # LLM-authored: may not be a list, or may hold non-dict junk. `"tag" in t`
    # on a non-dict (e.g. an int) raises TypeError and kills every render tick —
    # manifest_at() validates the shape and drops junk.
    return manifest_at(os.getcwd())


def _short_action(block):
    name = block.get("name", "?")
    inp = block.get("input", {}) or {}
    for k in ("file_path", "command", "pattern", "query", "path", "prompt"):
        if k in inp and isinstance(inp[k], str):
            v = inp[k].strip().replace("\n", " ")
            return f"{name} {v[:44]}"
    return name


def summarize_agent(objs):
    """Summarize one subagent's transcript (a list of JSONL objects)."""
    tag = agent_id = None
    out_tokens = calls = ctx_tokens = 0
    action = None
    last_types = last_role = None
    for o in objs:
        agent_id = agent_id or o.get("agentId")
        msg = o.get("message") or {}
        role = msg.get("role")
        content = msg.get("content")
        texts, types = [], []
        if isinstance(content, str):
            texts.append(content)
            types.append("text")
        elif isinstance(content, list):
            for b in content:
                if not isinstance(b, dict):
                    continue
                types.append(b.get("type"))
                if b.get("type") == "text":
                    texts.append(b.get("text", ""))
                elif b.get("type") == "tool_use":
                    calls += 1
                    action = _short_action(b)
        if tag is None:
            for t in texts:
                m = TAG_RE.search(t)
                if m:
                    tag = m.group(1)
                    break
        u = msg.get("usage") or {}
        out_tokens += u.get("output_tokens", 0) or 0
        # ↓ context = the input pushed *down* to the model on one turn (fresh
        # input + cache reads + cache writes). This is what Claude Code's native
        # panel shows as "↓ N tokens" — dominated by cache reads, so far bigger
        # than output. Track the peak turn to reconcile with the native number.
        turn_ctx = ((u.get("input_tokens", 0) or 0)
                    + (u.get("cache_read_input_tokens", 0) or 0)
                    + (u.get("cache_creation_input_tokens", 0) or 0))
        if turn_ctx > ctx_tokens:
            ctx_tokens = turn_ctx
        if role in ("assistant", "user"):
            last_role, last_types = role, types
    # Done = last turn is the assistant's final answer (text, no pending tool).
    # stop_reason is unreliable in per-agent transcripts (often null).
    done = last_role == "assistant" and "text" in (last_types or []) \
        and "tool_use" not in (last_types or [])
    return {
        "tag": tag,
        "agent_id": agent_id,
        "out_tokens": out_tokens,
        "ctx_tokens": ctx_tokens,
        "calls": calls,
        "action": action,
        "done": done,
    }


def bar(frac):
    frac = max(0.0, min(1.0, frac))
    fill = round(frac * BARW)
    return "▓" * fill + "░" * (BARW - fill)


def human(n):
    return f"{n/1000:.1f}k" if n >= 1000 else str(n)


def _int(v, default):
    # manifest is LLM-authored: budgets may arrive as "12" or garbage.
    try:
        return int(v)
    except (TypeError, ValueError):
        return default


def manifest_mtime():
    try:
        return os.path.getmtime(os.path.join(os.getcwd(), ".cortext", "tasks.json"))
    except OSError:
        return None


def render(subdir, manifest, tick):
    files = agent_files(subdir)
    # Scope to the current run: the manifest is rewritten on each dispatch, so
    # drop agent files older than it (stale tags from earlier runs in the same
    # session would otherwise show as duplicates).
    cutoff = manifest_mtime()
    if cutoff:
        files = [f for f in files if os.path.getmtime(f) >= cutoff - 1]
    rows = [summarize_agent(load_objs(f)) for f in files]
    tagged = [r for r in rows if r["tag"]]
    rows = tagged if tagged else rows  # fall back to untagged if none tagged

    header = os.path.basename(os.path.dirname(subdir)) if subdir else "no session"
    lines = [f"cortext monitor  (session {header[:12]})   ^C to quit", ""]
    if not rows:
        lines.append("  no cortext subagents yet — dispatch some and they'll appear here")
    for i, r in enumerate(sorted(rows, key=lambda x: x["tag"] or x["agent_id"] or "")):
        tag = r["tag"] or (r["agent_id"] or f"agent{i+1}")[:6]
        m = manifest.get(tag, {})
        label = m.get("label", tag)
        mode = m.get("mode", "?")
        tool_budget = max(1, _int(m.get("tool_budget"), 15))
        token_budget = max(1, _int(m.get("token_budget"), 40000))
        status = "✓ done" if r["done"] else SPIN[tick % len(SPIN)] + " run"
        pct = min(100, round(100 * r["calls"] / tool_budget))
        lines.append(
            f"  {tag:<6} {mode:<5} {bar(r['calls']/tool_budget)} {pct:3d}%  "
            f"({r['calls']}/{tool_budget} calls)  {status}"
        )
        lines.append(
            f"         out  {bar(r['out_tokens']/token_budget)} "
            f"{human(r['out_tokens'])}/{human(token_budget)}  ↓{human(r['ctx_tokens'])} ctx   {label}"
        )
        if r["action"]:
            lines.append(f"         • {r['action']}")
        lines.append("")
    return "\n".join(lines)


def main(argv):
    if "--selftest" in argv:
        return selftest()
    once = "--once" in argv
    argv = [a for a in argv if not a.startswith("--")]
    subdir = argv[0] if argv else newest_subagents_dir()
    if not subdir:
        print("cortext-monitor: no Claude Code sessions found.")
        print("  looked under:", os.path.expanduser("~/.claude/projects"))
        return 1
    # Live key handling needs a real TTY on BOTH ends: stdout to draw, stdin for
    # termios/cbreak. stdin-not-a-tty (e.g. `cortext-monitor < /dev/null`) would
    # crash tcgetattr, so fall back to a single frame like --once.
    if once or not sys.stdout.isatty() or not sys.stdin.isatty():
        print(render(subdir, load_manifest(), 0))
        return 0

    import select, termios, tty  # unix TTY only; --once/pipes never reach here

    def draw(frame):
        # home, rewrite each line clearing to EOL, then clear everything below.
        body = "\n".join(l + "\x1b[K" for l in frame.split("\n"))
        sys.stdout.write("\x1b[H" + body + "\x1b[J")
        sys.stdout.flush()

    keyhint = "  [q]uit   [r]escan session   [c]lear"
    auto = not argv  # subdir was auto-resolved → 'r' can re-pick the live session
    fd = sys.stdin.fileno()
    old_attr = termios.tcgetattr(fd)
    tick = 0
    full_clear = True
    sys.stdout.write("\x1b[?1049h\x1b[?25l")  # alt screen, hide cursor
    sys.stdout.flush()
    try:
        tty.setcbreak(fd)  # read keys unbuffered, no Enter needed
        while True:
            if full_clear:
                sys.stdout.write("\x1b[2J")
                full_clear = False
            draw(render(subdir, load_manifest(), tick) + "\n" + keyhint)
            tick += 1
            # poll a key for up to 1s instead of a blind sleep — this IS the refresh tick.
            if select.select([sys.stdin], [], [], 1.0)[0]:
                ch = sys.stdin.read(1)
                if ch == "":  # stdin EOF (Ctrl-D / closed) — quit, don't busy-spin
                    break
                if ch in ("q", "Q", "\x03"):  # q or Ctrl-C
                    break
                if ch in ("r", "R"):  # rescan: re-pick the live session + full repaint
                    if auto:
                        subdir = newest_subagents_dir() or subdir
                    full_clear = True
                elif ch in ("c", "C"):  # clear artifacts and repaint
                    full_clear = True
    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_attr)
        sys.stdout.write("\x1b[?25h\x1b[?1049l")  # show cursor, leave alt screen
        sys.stdout.flush()
    return 0


def selftest():
    objs = [
        {"agentId": "z9", "message": {"role": "user", "content": "[cortext:t1] find the bug"}},
        {"agentId": "z9", "message": {"role": "assistant", "stop_reason": "tool_use",
         "usage": {"output_tokens": 300, "input_tokens": 8, "cache_read_input_tokens": 55000},
         "content": [{"type": "tool_use", "name": "Read", "input": {"file_path": "cart.swift"}}]}},
        {"agentId": "z9", "message": {"role": "assistant", "stop_reason": "end_turn",
         "usage": {"output_tokens": 120, "input_tokens": 8, "cache_read_input_tokens": 40000},
         "content": [{"type": "text", "text": "found: cart.swift:42"}]}},
    ]
    s = summarize_agent(objs)
    assert s["tag"] == "t1", s
    assert s["calls"] == 1 and s["out_tokens"] == 420, s
    # ↓ context is the PEAK turn (55008), not the sum — reconciles with native.
    assert s["ctx_tokens"] == 55008, s
    assert s["done"] is True, s
    assert s["action"] == "Read cart.swift", s
    assert s["agent_id"] == "z9", s

    # list-form content on the initial user prompt, unfinished agent
    s2 = summarize_agent([
        {"agentId": "y8", "message": {"role": "user",
         "content": [{"type": "text", "text": "[cortext:t2] fix it"}]}},
        {"agentId": "y8", "message": {"role": "assistant", "stop_reason": "tool_use",
         "usage": {"output_tokens": 500},
         "content": [{"type": "tool_use", "name": "Edit", "input": {"file_path": "cart.swift"}}]}},
    ])
    assert s2["tag"] == "t2" and s2["done"] is False and s2["action"] == "Edit cart.swift", s2

    assert bar(0.5) == "▓" * 5 + "░" * 5
    assert human(8200) == "8.2k" and human(120) == "120"
    # LLM-authored manifests: string/garbage budgets must not crash render.
    assert _int("12", 15) == 12 and _int(None, 15) == 15 and _int("x", 15) == 15
    # A malformed manifest must degrade to {}, never crash a render tick.
    import tempfile as _tf
    _d = _tf.mkdtemp(); _cwd = os.getcwd(); os.chdir(_d); os.makedirs(".cortext")
    try:
        for bad in ("[1, 2, \"x\"]", "{\"not\": \"a list\"}", "42", "garbage{"):
            with open(os.path.join(".cortext", "tasks.json"), "w") as _f:
                _f.write(bad)
            assert load_manifest() == {}, bad
        # a well-formed entry still loads, junk siblings dropped
        with open(os.path.join(".cortext", "tasks.json"), "w") as _f:
            _f.write('[{"tag": "t1", "label": "ok"}, 7]')
        assert load_manifest() == {"t1": {"tag": "t1", "label": "ok"}}
    finally:
        os.chdir(_cwd)
    print("selftest ok")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
