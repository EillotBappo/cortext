#!/usr/bin/env python3
"""cortext-status — main statusLine renderer with an inline cortext run summary.

Claude Code calls this once per refresh with a session JSON on stdin. We render a
normal status line (model · dir · git branch) and, WHEN a cortext run is active,
append a one-glance summary — `⛵ 3/5 · 218k out · t4 run` — so live progress lives
in the main bar without a second terminal. When no run is active it's just a plain
status line, so it never leaves the bar empty.

Because this claims the single main statusLine slot, it renders a sensible default
rather than hijacking it with cortext-only content.

  cortext-status            # reads stdin, prints one status line
  cortext-status --selftest # self-check
"""
import json, os, sys
from importlib.machinery import SourceFileLoader

try:
    _mon = SourceFileLoader(
        "cortext_monitor",
        os.path.join(os.path.dirname(os.path.abspath(__file__)), "cortext-monitor"),
    ).load_module()
except Exception:
    _mon = None


def human(n):
    n = n or 0
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    return f"{n/1000:.1f}k" if n >= 1000 else str(n)


def git_branch(root):
    try:
        with open(os.path.join(root, ".git", "HEAD")) as f:
            head = f.read().strip()
    except OSError:
        return None
    if head.startswith("ref: refs/heads/"):
        return head[len("ref: refs/heads/"):]
    return head[:7] if head else None  # detached HEAD → short sha


def session_subdir(data, root):
    """The subagents dir for THIS session — no 'newest' guessing, so a second
    Claude session in the same project can't hijack the summary. Claude Code puts
    the session's transcript path (and id) in the statusLine payload."""
    tpath = data.get("transcript_path") if isinstance(data, dict) else None
    if tpath:
        return _mon._subagents_of(tpath)  # .../<session_id>/subagents
    sid = data.get("session_id") if isinstance(data, dict) else None
    if sid:
        base = os.path.expanduser("~/.claude/projects")
        return os.path.join(base, _mon._slug(root), sid, "subagents")
    return _mon.newest_subagents_dir()  # last resort (no session info in payload)


def cortext_summary(root, subdir):
    """'▓▓░ 3/5 · 218k out · t4 run' for the active run, or None if none is active.
    Active = a manifest exists and fresh agent transcripts sit at/after its mtime."""
    if _mon is None:
        return None
    manifest = _mon.manifest_at(root)
    try:
        cutoff = os.path.getmtime(os.path.join(root, ".cortext", "tasks.json"))
    except OSError:
        return None
    files = [f for f in _mon.agent_files(subdir)
             if os.path.getmtime(f) >= cutoff - 1]
    rows = [_mon.summarize_agent(_mon.load_objs(f)) for f in files]
    rows = [r for r in rows if r["tag"]]
    if not rows:
        return None
    total = max(len(manifest), len(rows)) if manifest else len(rows)
    done = sum(1 for r in rows if r["done"])
    out = sum(r["out_tokens"] for r in rows)
    running = next((r["tag"] for r in sorted(rows, key=lambda x: x["tag"]) if not r["done"]), None)
    frac = done / total if total else 0.0
    tail = f" · {running} run" if running else " · ✓"
    off = _mon.offloaded(rows)
    return f"⛵ {_mon.bar(frac)} {done}/{total} · {human(out)} out · {human(off)} off-ctx{tail}"


def render(data):
    data = data if isinstance(data, dict) else {}
    ws = data.get("workspace") or {}
    root = (os.environ.get("CLAUDE_PROJECT_DIR")
            or ws.get("project_dir") or ws.get("current_dir")
            or data.get("cwd") or os.getcwd())
    cur = ws.get("current_dir") or data.get("cwd") or root
    model = (data.get("model") or {}).get("display_name") or "?"

    parts = [model, os.path.basename(os.path.normpath(cur)) or cur]
    br = git_branch(root)
    if br:
        parts.append(br)
    line = "  ".join(parts)
    summary = cortext_summary(root, session_subdir(data, root))
    return f"{line}   {summary}" if summary else line


def selftest():
    data = {"model": {"display_name": "Opus 4.8"},
            "workspace": {"current_dir": "/tmp/proj", "project_dir": "/tmp/proj"}}
    line = render(data)
    assert "Opus 4.8" in line and "proj" in line, line
    # no active run → no cortext suffix, plain line
    assert "⛵" not in line, line
    # bad payloads never crash
    assert isinstance(render([]), str) and isinstance(render("x"), str)
    assert human(218000) == "218.0k"
    # session targeting: transcript_path wins over 'newest' guessing
    sub = session_subdir({"transcript_path": "/a/b/SID123.jsonl"}, "/r")
    assert sub.endswith(os.path.join("SID123", "subagents")), sub
    sub2 = session_subdir({"session_id": "ZZ"}, "/proj")
    assert sub2.endswith(os.path.join("ZZ", "subagents")) and "proj" in sub2, sub2
    print("selftest ok")
    return 0


def main(argv):
    if "--selftest" in argv:
        return selftest()
    try:
        data = json.load(sys.stdin)
    except (ValueError, OSError):
        data = {}
    print(render(data))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
